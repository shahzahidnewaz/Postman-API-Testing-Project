  "item": [
    {
      "name": "Log In",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login Successful\", () => {\r",
              "pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Success response\", () => { \r",
              "pm.expect(pm.response.code) .to.be.oneOf([200,201,204]);\r",
              "});\r",
              "\r",
              "let jsonData=pm.response.json();\r",
              "pm.environment.set(\"accessToken\",jsonData.accessToken);\r",
              "\r",
              "console.log(pm.environment.get(\"accessToken\")); "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Auth User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Body matches string\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Emily\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Security header present\", () => {\r",
              "    pm.expect( pm.response.headers.has( \"X-Content-Type-Options\")) .to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
